{
    "name": "mini-cookpad/ci4",
    "description": "Mini Cookpad - Platform Resep Autentik dari Chef Terverifikasi",
    "require": {
        "codeigniter4/framework": "4.5.8",
        "php": ">=8.1"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9"
    },
    "scripts": {
        "post-update-cmd": [
            "@php spark configure"
        ]
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        },
        "policy": {
            "advisories": {
                "block": false
            }
        }
    }
}
